---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pixelmix — coming soon"
  description="Anime prints, hand-picked. Launching soon."
>
  <section class="splash" aria-label="Coming soon">
    <div class="splash-glow" aria-hidden="true"></div>

    <div class="splash-content">
      <span class="hero-eyebrow">Coming soon</span>
      <h1 class="splash-title">
        Anime prints, <em>hand-picked</em>.
      </h1>
      <p class="splash-sub">
        A small shop of museum-grade prints. One color story at a time.
        We're putting the final pieces in place — a real catalog,
        proper checkout, and a name on every print.
      </p>
      <div class="splash-cta-row">
        <a class="hero-cta" href="/contact">
          Get in touch <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a class="splash-secondary" href="/gallery">
          Sneak peek the gallery →
        </a>
      </div>
      <p class="splash-foot">
        pixelmix.co &nbsp;·&nbsp; est. 2026
      </p>
    </div>
  </section>
</Layout>

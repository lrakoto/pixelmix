---
const pathname = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

// Highlight the link that matches the current path. Treat "/" as a special
// case so it doesn't match every path.
function isActive(href: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Pixelmix home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-name">Pixelmix</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {links.map(({ href, label }) => (
          <li>
            <a href={href} class:list={[{ active: isActive(href) }]}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
